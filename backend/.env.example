# backend/.env.example — COMPLETE FINAL VERSION
# Copy to .env, fill every value, NEVER commit .env to git

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.nipino-manabu.com

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nipino_manabu
DB_USER=nipino_user
DB_PASS=REPLACE_WITH_STRONG_PASSWORD
DB_SSLMODE=require

# ── JWT  →  generate: openssl rand -hex 64 ─────────────────────────────────────
JWT_SECRET=REPLACE_WITH_128_CHAR_HEX_FROM_OPENSSL
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ── SMTP (SendGrid free tier: 100 emails/day) ──────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@nipino-manabu.com
SMTP_FROM_NAME=Nipino-Manabu

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Firebase (push notifications + Crashlytics) ────────────────────────────────
# From Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_ID",...}

# ── Apple IAP ──────────────────────────────────────────────────────────────────
# App Store Connect → Apps → your app → App Information → Shared Secret
APPLE_SHARED_SECRET=YOUR_APPLE_SHARED_SECRET_32_CHAR_HEX

# ── Google IAP ─────────────────────────────────────────────────────────────────
ANDROID_PACKAGE_NAME=com.nipino.manabu
# Google Play Console → Setup → API access → Service account JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_ID",...}

# ── Stripe (web coin store) ────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
# dashboard.stripe.com → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

# ── PayPal (web coin store — account: eicalla2011@gmail.com) ──────────────────
# developer.paypal.com → My Apps & Credentials → create app → Live credentials
PAYPAL_CLIENT_ID=YOUR_PAYPAL_LIVE_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_LIVE_CLIENT_SECRET
# developer.paypal.com → Notifications → Webhooks → your webhook ID
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID

# ── Vultr Object Storage (images + audio for quiz questions) ───────────────────
# my.vultr.com → Object Storage → Add Object Storage → Tokyo region
STORAGE_ENDPOINT=sjc1.vultrobjects.com
STORAGE_ACCESS_KEY=YOUR_VULTR_OBJECT_STORAGE_ACCESS_KEY
STORAGE_SECRET_KEY=YOUR_VULTR_OBJECT_STORAGE_SECRET_KEY
STORAGE_BUCKET=nipino-manabu
STORAGE_REGION=ewr
STORAGE_PUBLIC_URL=https://nipino-manabu.sjc1.vultrobjects.com

# ── Slack alerts (optional — errors ping this webhook) ─────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
